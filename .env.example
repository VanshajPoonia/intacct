# Hosted Supabase project values.
# Keep this file as placeholders only. Put real values in .env.local or Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx

# Legacy fallbacks are still supported for local CLI / self-hosted compatibility.
# Only use these if your local stack exposes legacy anon / service_role keys.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Optional Supabase CLI vars for linked hosted operations.
# Fill these in .env.local only if you want the setup script or CLI to link to a hosted project.
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_REF=wdasdwadsd
SUPABASE_DB_PASSWORD=your-remote-db-password

# Local app runtime values. For Vercel production, set NEXT_PUBLIC_APP_URL to:
# https://accura.kreativvantage.com
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_DATA_SOURCE=supabase
NEXT_PUBLIC_AUTH_SOURCE=mock

# Optional local-stack overrides for DB development.
# Only uncomment these if you want the app talking to the local stack
# instead of the hosted project after `npx supabase start`.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# If your local stack supports new opaque keys, use these:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=local-publishable-key-from-your-stack
# SUPABASE_SECRET_KEY=local-secret-key-from-your-stack
# If your local stack only exposes legacy keys, use the fallbacks instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=local-anon-key-from-supabase-start
# SUPABASE_SERVICE_ROLE_KEY=local-service-role-key-from-supabase-start
